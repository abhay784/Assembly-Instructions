# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# LLM backend: "claude" or "vllm" (default: vllm)
LLM_BACKEND=claude

# Required when LLM_BACKEND=claude
ANTHROPIC_API_KEY=

# Optional — defaults to claude-opus-4-7
#CLAUDE_MODEL=claude-sonnet-4-6

# Required when LLM_BACKEND=vllm
# VLLM_BASE_URL=http://localhost:8001/v1
# VLLM_MODEL=mistral-7b

# Optional paths for local testing fixtures
# PART_HISTORY_DB=fixtures/part_history.json
# MATE_GRAPH_DB=fixtures/mate_graph.json
